@{
    ViewData["Title"] = "Relatórios de Vendas";
}

<div class="mb-4">
    <h1 class="display-4"><i class="text-primary bi bi-search"></i> @ViewData["Title"]</h1>
    <p class="text-muted">Selecione o tipo de busca para filtrar os registros de 2026.</p>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0"><i class="bi bi-list-check"></i> Busca Simples</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="SimpleSearch">
                    <div class="form-floating mb-3">
                        <input type="date" name="minDate" class="form-control" placeholder=" " />
                        <label>Data Inicial</label>
                    </div>
                    <div class="form-floating mb-4">
                        <input type="date" name="maxDate" class="form-control" placeholder=" " />
                        <label>Data Final</label>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm">Consultar Vendas</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-dark text-white py-3">
                <h4 class="mb-0"><i class="bi bi-collection"></i> Busca Agrupada</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="GroupingSearch">
                    <div class="form-floating mb-3">
                        <input type="date" name="minDate" class="form-control" placeholder=" " />
                        <label>Data Inicial</label>
                    </div>
                    <div class="form-floating mb-4">
                        <input type="date" name="maxDate" class="form-control" placeholder=" " />
                        <label>Data Final</label>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-dark btn-lg shadow-sm">Consultar por Setor</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>