@model IEnumerable<SalesWebMvc.Models.SalesRecord>

@{
    ViewData["Title"] = "Busca Simples";
}

<div class="card shadow border-0 mb-4">
    <div class="card-body bg-light rounded shadow-sm">
        <form class="row g-3 align-items-end" role="search">
            <div class="col-md-4">
                <label class="form-label fw-bold">Data Mínima</label>
                <input type="date" class="form-control" name="minDate" value="@ViewData["minDate"]" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold">Data Máxima</label>
                <input type="date" class="form-control" name="maxDate" value="@ViewData["maxDate"]" />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100 shadow-sm">Filtrar Resultado</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow border-0">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
        <h3 class="h5 mb-0">Total de Vendas no Período</h3>
        <span class="badge bg-white text-primary fs-5">@Model.Sum(obj => obj.Amount).ToString("C")</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light text-primary">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.Id)</th>
                        <th>@Html.DisplayNameFor(model => model.Date)</th>
                        <th>@Html.DisplayNameFor(model => model.Seller)</th>
                        <th>Departamento</th>
                        <th>@Html.DisplayNameFor(model => model.Amount)</th>
                        <th>@Html.DisplayNameFor(model => model.Status)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">@Html.DisplayFor(modelItem => item.Id)</td>
                            <td>@item.Date.ToString("dd/MM/yyyy")</td>
                            <td>@Html.DisplayFor(modelItem => item.Seller.Name)</td>
                            <td>@Html.DisplayFor(modelItem => item.Seller.Department.Name)</td>
                            <td class="fw-bold">@item.Amount.ToString("C")</td>
                            <td>
                                @if (item.Status.ToString() == "Billed")
                                {
                                    <span class="badge bg-success">Faturado</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">@item.Status</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>