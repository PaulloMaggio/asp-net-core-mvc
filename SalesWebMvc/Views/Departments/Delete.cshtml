@model SalesWebMvc.Models.Department

@{
    ViewData["Title"] = "Excluir Departamento";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm mt-5">
            <div class="card-header bg-danger text-white py-3">
                <h4 class="mb-0">Atenção! Confirma a exclusão?</h4>
            </div>
            <div class="card-body p-4 text-center">
                <p class="lead">Você está prestes a apagar o departamento:</p>
                <h3 class="display-6 fw-bold">@Model.Name</h3>
                <p class="text-muted">Essa ação não poderá ser desfeita e pode afetar os vendedores vinculados.</p>
                
                <form asp-action="Delete" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger btn-lg px-5">Sim, Excluir</button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5 ms-2">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>