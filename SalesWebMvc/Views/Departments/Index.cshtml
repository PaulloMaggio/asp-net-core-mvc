@model IEnumerable<SalesWebMvc.Models.Department>

@{
    ViewData["Title"] = "Departamentos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-4"><i class="text-primary bi bi-building"></i> @ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-lg"></i> Novo Departamento
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="px-4 py-3">@Html.DisplayNameFor(model => model.Name)</th>
                    <th class="text-end px-4 py-3">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle px-4">
                            <span class="fw-bold text-dark">@Html.DisplayFor(modelItem => item.Name)</span>
                        </td>
                        <td class="text-end px-4 py-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm me-1">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm me-1">Detalhes</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Excluir</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>