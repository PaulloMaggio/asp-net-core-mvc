@model SalesWebMvc.Models.Department

@{
    ViewData["Title"] = "Novo Departamento";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow border-0 mt-5">
            <div class="card-header bg-primary text-white py-3 text-center">
                <h4 class="mb-0">Cadastrar Departamento</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="form-floating mb-4">
                        <input asp-for="Name" class="form-control" placeholder=" " id="nameInput" autocomplete="off" />
                        <label asp-for="Name">Nome do Departamento</label>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm">Criar Departamento</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar e Voltar</a>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="text-center mt-3 text-muted">
            <small>Certifique-se de que o nome seja único no sistema.</small>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}