@model SalesWebMvc.Models.ViewModels.SellerFormViewModel

@{
    ViewData["Title"] = "Create Seller";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h2 class="h4 mb-0 text-center"><i class="bi bi-person-plus"></i> @ViewData["Title"]</h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Seller.Name" class="form-label fw-bold"></label>
                            <input asp-for="Seller.Name" class="form-control" placeholder="Full Name" />
                            <span asp-validation-for="Seller.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Seller.Email" class="form-label fw-bold"></label>
                            <input asp-for="Seller.Email" class="form-control" placeholder="email@example.com" />
                            <span asp-validation-for="Seller.Email" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Seller.BirthDate" class="form-label fw-bold"></label>
                                <input asp-for="Seller.BirthDate" class="form-control" type="date" />
                                <span asp-validation-for="Seller.BirthDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Seller.BaseSalary" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="Seller.BaseSalary" class="form-control" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Seller.BaseSalary" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Seller.DepartmentId" class="form-label fw-bold">Department</label>
                            <select asp-for="Seller.DepartmentId"
                                    asp-items="@(new SelectList(Model.Departments, "Id", "Name"))"
                                    class="form-select border-primary-subtle">
                                <option value="">-- Select Department --</option>
                            </select>
                            <span asp-validation-for="Seller.DepartmentId" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm">
                                <i class="bi bi-check-circle"></i> Create
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill mt-2">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}