@model SalesWebMvc.Models.ViewModels.SellerFormViewModel

@{
    ViewData["Title"] = "Novo Vendedor";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0 mt-4">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0 text-center">Cadastrar Vendedor</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Seller.Name" class="form-control" placeholder=" " />
                        <label asp-for="Seller.Name">Nome Completo</label>
                        <span asp-validation-for="Seller.Name" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Seller.Email" class="form-control" placeholder=" " />
                        <label asp-for="Seller.Email">E-mail</label>
                        <span asp-validation-for="Seller.Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Seller.BirthDate" class="form-control" placeholder=" " />
                        <label asp-for="Seller.BirthDate">Data de Nascimento</label>
                        <span asp-validation-for="Seller.BirthDate" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Seller.BaseSalary" class="form-control" placeholder=" " />
                        <label asp-for="Seller.BaseSalary">Salário Base</label>
                        <span asp-validation-for="Seller.BaseSalary" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <select asp-for="Seller.DepartmentId" asp-items="@(new SelectList(Model.Departments, "Id", "Name"))" class="form-select"></select>
                        <label asp-for="Seller.DepartmentId">Departamento</label>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm">Criar Vendedor</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Voltar para Lista</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}