@model SalesWebMvc.Models.Seller

@{
    ViewData["Title"] = "Detalhes do Vendedor";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white py-3 text-center">
                    <h3 class="mb-0">@Model.Name</h3>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4 text-center">
                        <div class="col-12">
                            <i class="bi bi-person-circle display-1 text-muted"></i>
                        </div>
                    </div>
                    
                    <div class="list-group list-group-flush border rounded">
                        <div class="list-group-item d-flex justify-content-between">
                            <span class="text-muted fw-bold">E-mail:</span>
                            <span>@Model.Email</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between">
                            <span class="text-muted fw-bold">Data de Nascimento:</span>
                            <span>@Model.BirthDate.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between">
                            <span class="text-muted fw-bold">Salário Base:</span>
                            <span class="text-success fw-bold">@Model.BaseSalary.ToString("C")</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between">
                            <span class="text-muted fw-bold">Departamento:</span>
                            <span class="badge bg-primary fs-6">@Model.Department.Name</span>
                        </div>
                    </div>

                    <div class="mt-4 d-flex justify-content-center gap-3">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-5">Editar</a>
                        <a asp-action="Index" class="btn btn-outline-secondary px-5">Voltar</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>