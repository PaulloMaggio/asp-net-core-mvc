@model SalesWebMvc.Models.Seller

@{
    ViewData["Title"] = "Seller Details";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white py-3">
                    <h2 class="h4 mb-0 text-center"><i class="bi bi-info-circle"></i> @ViewData["Title"]</h2>
                </div>
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="display-1 text-secondary">
                            <i class="bi bi-person-badge"></i>
                        </div>
                        <h3 class="mt-2 text-primary">@Html.DisplayFor(model => model.Name)</h3>
                        <span class="badge bg-secondary">ID: @Model.Id</span>
                    </div>

                    <div class="bg-light p-4 rounded-3 border">
                        <dl class="row mb-0">
                            <dt class="col-sm-4 fw-bold text-dark mb-3">
                                <i class="bi bi-envelope me-1"></i> @Html.DisplayNameFor(model => model.Email)
                            </dt>
                            <dd class="col-sm-8 text-secondary mb-3">
                                @Html.DisplayFor(model => model.Email)
                            </dd>

                            <dt class="col-sm-4 fw-bold text-dark mb-3">
                                <i class="bi bi-calendar-event me-1"></i> @Html.DisplayNameFor(model => model.BirthDate)
                            </dt>
                            <dd class="col-sm-8 text-secondary mb-3">
                                @Model.BirthDate.ToString("dd/MM/yyyy")
                            </dd>

                            <dt class="col-sm-4 fw-bold text-dark mb-3">
                                <i class="bi bi-cash-stack me-1"></i> @Html.DisplayNameFor(model => model.BaseSalary)
                            </dt>
                            <dd class="col-sm-8 text-secondary mb-3 fw-bold">
                                @Model.BaseSalary.ToString("C")
                            </dd>

                            <dt class="col-sm-4 fw-bold text-dark mb-0">
                                <i class="bi bi-building me-1"></i> @Html.DisplayNameFor(model => model.Department)
                            </dt>
                            <dd class="col-sm-8 text-secondary mb-0">
                                @Html.DisplayFor(model => model.Department.Name)
                            </dd>
                        </dl>
                    </div>

                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning px-4 rounded-pill shadow-sm">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>