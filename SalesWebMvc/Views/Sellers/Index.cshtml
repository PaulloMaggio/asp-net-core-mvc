@model IEnumerable<SalesWebMvc.Models.Seller>

@{
    ViewData["Title"] = "Sellers";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="display-6 text-primary mb-0"><i class="bi bi-people-fill"></i> @ViewData["Title"]</h2>
            <p class="text-muted">Manage your sales team and performance</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill shadow-sm">
            <i class="bi bi-person-plus-fill"></i> Create New
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">
                            <i class="bi bi-person"></i> @Html.DisplayNameFor(model => model.Name)
                        </th>
                        <th>
                            <i class="bi bi-envelope"></i> @Html.DisplayNameFor(model => model.Email)
                        </th>
                        <th>
                            <i class="bi bi-calendar-event"></i> @Html.DisplayNameFor(model => model.BirthDate)
                        </th>
                        <th>
                            <i class="bi bi-cash-stack"></i> @Html.DisplayNameFor(model => model.BaseSalary)
                        </th>
                        <th class="text-center pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-secondary">
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Email)
                            </td>
                            <td>
                                @item.BirthDate.ToString("dd/MM/yyyy")
                            </td>
                            <td>
                                @item.BaseSalary.ToString("C")
                            </td>
                            <td class="text-center pe-4">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm d-flex align-items-center">
                                        <i class="bi bi-pencil-square me-1"></i> Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm d-flex align-items-center">
                                        <i class="bi bi-eye me-1"></i> Details
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm d-flex align-items-center">
                                        <i class="bi bi-trash me-1"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>