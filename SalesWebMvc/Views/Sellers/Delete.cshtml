@model SalesWebMvc.Models.Seller

@{
    ViewData["Title"] = "Delete Seller";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow-sm">
                <div class="card-header bg-danger text-white py-3 text-center">
                    <h2 class="h4 mb-0"><i class="bi bi-exclamation-triangle-fill"></i> @ViewData["Title"]</h2>
                </div>
                <div class="card-body p-4">
                    <h5 class="text-center mb-4 text-secondary">Are you sure you want to delete this?</h5>

                    <div class="bg-light p-3 rounded mb-4">
                        <dl class="row mb-0">
                            <dt class="col-sm-4 fw-bold">
                                @Html.DisplayNameFor(model => model.Name)
                            </dt>
                            <dd class="col-sm-8 text-secondary">
                                @Html.DisplayFor(model => model.Name)
                            </dd>

                            <dt class="col-sm-4 fw-bold">
                                @Html.DisplayNameFor(model => model.Email)
                            </dt>
                            <dd class="col-sm-8 text-secondary">
                                @Html.DisplayFor(model => model.Email)
                            </dd>

                            <dt class="col-sm-4 fw-bold">
                                @Html.DisplayNameFor(model => model.BirthDate)
                            </dt>
                            <dd class="col-sm-8 text-secondary">
                                @Model.BirthDate.ToString("dd/MM/yyyy")
                            </dd>

                            <dt class="col-sm-4 fw-bold">
                                @Html.DisplayNameFor(model => model.BaseSalary)
                            </dt>
                            <dd class="col-sm-8 text-secondary font-monospace">
                                @Model.BaseSalary.ToString("C")
                            </dd>
                        </dl>
                    </div>

                    <form asp-action="Delete" class="d-grid gap-2">
                        <input type="hidden" asp-for="Id" />
                        <button type="submit" class="btn btn-danger btn-lg rounded-pill shadow-sm">
                            <i class="bi bi-trash"></i> Confirm Delete
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill mt-1">
                            <i class="bi bi-arrow-left"></i> No, Back to List
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>