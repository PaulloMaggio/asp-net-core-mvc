@model SalesWebMvc.Models.Seller

@{
    ViewData["Title"] = "Excluir Vendedor";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm mt-4">
            <div class="card-header bg-danger text-white py-3 text-center">
                <h4 class="mb-0">Confirmar Exclusão</h4>
            </div>
            <div class="card-body p-4 text-center">
                <i class="bi bi-exclamation-octagon text-danger display-4 mb-3"></i>
                <p class="lead">Tem certeza que deseja remover o vendedor?</p>
                <h3 class="fw-bold mb-4">@Model.Name</h3>
                
                <div class="bg-light p-3 rounded mb-4 text-start">
                    <small class="text-muted d-block text-center mb-2">Resumo dos dados:</small>
                    <div class="d-flex justify-content-between px-3">
                        <span>Email:</span> <span class="fw-bold">@Model.Email</span>
                    </div>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg shadow-sm">Sim, Confirmar Exclusão</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Não, Voltar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>